PORT=8080
APP_ENV=development

# Mapillary Graph API v4 erişim token'ı
# https://mapillary.com/dashboard/developers adresinden alınır
MAPILLARY_ACCESS_TOKEN=

# Wiro AI API anahtarı
WIRO_API_KEY=
WIRO_SECRET=

# Türkçe yazım düzeltme metin modeli (owner/slug formatı, ör: openai/gpt-oss-20b)
WIRO_TEXT_MODEL=openai/gpt-oss-20b
# false yapılırsa yalnızca yerel Türkçe düzeltme kullanılır
WIRO_TEXT_POLISH=true

# SQLite mesaj veritabanı yolu (opsiyonel, varsayılan: ./data/messages.db)
DB_PATH=
